{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Active Java File",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$ErrorActionPreference='Stop'; Set-Location '${fileDirname}'; javac '${fileBasename}'; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; java '${fileBasenameNoExtension}'"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "detail": "Compile and run the currently open Java file."
    }
  ]
}
